cmake_minimum_required(VERSION 3.15)
project(kddockwidgets_qt6_vendor_smoke_test CXX)

list(PREPEND CMAKE_PREFIX_PATH "@CMAKE_CURRENT_BINARY_DIR@/@PROJECT_NAME@-prefix/install")
set(Qt6_DIR "@Qt6_DIR@")

find_package(Qt6 REQUIRED COMPONENTS Widgets Quick QuickControls2)
find_package(KDDockWidgets-qt6 REQUIRED CONFIG)

if(NOT TARGET KDAB::kddockwidgets)
  message(FATAL_ERROR "Expected imported target KDAB::kddockwidgets was not found.")
endif()
